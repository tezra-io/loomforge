{
  "name": "@tezra-io/loomforge",
  "version": "0.3.0",
  "type": "module",
  "description": "Slim local workflow engine for agentic software delivery",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tezra-io/loomforge.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/tezra-io/loomforge",
  "bugs": {
    "url": "https://github.com/tezra-io/loomforge/issues"
  },
  "bin": {
    "loomforge": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "templates/",
    "scripts/postinstall.js",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "postinstall": "node scripts/postinstall.js",
    "dev": "tsx src/cli/index.ts",
    "dev:watch": "tsx watch src/cli/index.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-version.js",
    "release": "changeset publish"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@linear/sdk": "^82.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
